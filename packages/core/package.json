{
  "name": "prosemirror-flat-list",
  "type": "module",
  "version": "0.5.8",
  "description": "Powerful list support for ProseMirror",
  "author": "ocavue <ocavue@gmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/ocavue/prosemirror-flat-list#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ocavue/prosemirror-flat-list.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/ocavue/prosemirror-flat-list/issues",
  "keywords": [
    "ProseMirror",
    "list"
  ],
  "sideEffects": false,
  "main": "./dist/prosemirror-flat-list.js",
  "module": "./dist/prosemirror-flat-list.js",
  "types": "./dist/prosemirror-flat-list.d.ts",
  "exports": {
    ".": {
      "types": "./dist/prosemirror-flat-list.d.ts",
      "require": "./dist/prosemirror-flat-list.cjs",
      "import": "./dist/prosemirror-flat-list.js"
    },
    "./dist/style.css": "./dist/style.css",
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "prepublishOnly": "pnpm run build",
    "test": "vitest"
  },
  "dependencies": {
    "prosemirror-commands": "^1.7.1",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-model": "^1.25.6",
    "prosemirror-safari-ime-span": "^1.0.2",
    "prosemirror-state": "^1.4.4",
    "prosemirror-transform": "^1.12.0",
    "prosemirror-view": "^1.41.8"
  },
  "devDependencies": {
    "@prosekit/core": "^0.12.2",
    "@prosekit/pm": "^0.1.17",
    "@tsdown/css": "^0.22.0",
    "@types/node": "^22.0.0",
    "@vitest/browser-playwright": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "dedent": "^1.7.2",
    "playwright": "^1.60.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "unified": "^11.0.5",
    "vite": "^7.3.3",
    "vitest": "^4.1.6",
    "vitest-browser-commands": "^0.2.1"
  },
  "typedocOptions": {
    "entryPoints": [
      "src/index.ts"
    ]
  }
}
